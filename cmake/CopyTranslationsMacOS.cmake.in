if(NOT DEFINED MEMENTO_BUNDLE_PATH)
    set(MEMENTO_BUNDLE_PATH "${CMAKE_INSTALL_PREFIX}/Memento.app")
endif()

if(NOT EXISTS "${MEMENTO_BUNDLE_PATH}")
    message(FATAL_ERROR
        "Cannot copy translations: ${MEMENTO_BUNDLE_PATH} does not exist."
    )
endif()

set(MEMENTO_TRANSLATION_QM_FILES "@MEMENTO_TRANSLATION_QM_FILES@")
set(
    MEMENTO_TRANSLATION_DESTINATION
    "${MEMENTO_BUNDLE_PATH}/Contents/Resources/translations"
)

message(STATUS "Copying translations into ${MEMENTO_TRANSLATION_DESTINATION}")
file(MAKE_DIRECTORY "${MEMENTO_TRANSLATION_DESTINATION}")
foreach(MEMENTO_TRANSLATION_QM_FILE IN LISTS MEMENTO_TRANSLATION_QM_FILES)
    file(COPY "${MEMENTO_TRANSLATION_QM_FILE}"
        DESTINATION "${MEMENTO_TRANSLATION_DESTINATION}"
    )
endforeach()
